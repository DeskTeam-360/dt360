# Canonical site URL (no trailing slash). Set in production for OG, sitemap, robots, JSON-LD.
# Example: https://deskteam360.com
NEXT_PUBLIC_SITE_URL=

# WordPress WPGraphQL (clone/staging recommended for local dev)
# Example: https://clone.deskteam360.com/endpoint
WORDPRESS_API_URL=
# Application password or JWT; optional Basic auth user for app passwords
WORDPRESS_USER=
WORDPRESS_AUTH_TOKEN=
# Site origin for Gravity Forms REST (no /endpoint path)
# Example: https://clone.deskteam360.com
WORDPRESS_SITE_URL=

# Book a Call → Gravity Forms form ID (clone: 59)
GRAVITY_FORMS_BOOK_A_CALL_ID=59

# reCAPTCHA site key (must match keys in WP → Forms → Settings → reCAPTCHA)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Temporary: true = hide reCAPTCHA in UI and API (also disable CAPTCHA on GF form or submissions may fail)
NEXT_PUBLIC_BOOK_A_CALL_SKIP_RECAPTCHA=false

# Blog: ISR / data cache (detik). Min 60. Default 600.
BLOG_REVALIDATE_SECONDS=

# Optional — Google Search Console verification token (google-site-verification meta value)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
