# Force Tailwind Oxide compiler to use WASI to bypass Windows Application Control blocking native .node binary
NAPI_RS_FORCE_WASI=1

# WordPress settings
WORDPRESS_API_URL=https://portal.deskteam360.com/endpoint
WORDPRESS_AUTH_TOKEN=
WORDPRESS_USER=
WORDPRESS_SITE_URL=https://portal.deskteam360.com
NEXT_PUBLIC_WORDPRESS_SITE_URL=https://portal.deskteam360.com
# Optional comma-separated extra image hostnames for next/image remotePatterns
WORDPRESS_IMAGE_HOSTS=
GRAVITY_FORMS_BOOK_A_CALL_ID=
GRAVITY_FORMS_CONTACT_ID=

# reCAPTCHA keys (site key = frontend; secret key = server, must match WordPress GF Settings)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Headless contact form: verify captcha on Next.js, skip on GF REST (requires export/wordpress-gf-rest-recaptcha-bypass.php on WP)
CONTACT_RECAPTCHA_SERVER_VERIFY=false
NEXT_PUBLIC_BOOK_A_CALL_SKIP_RECAPTCHA=false
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
